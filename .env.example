# App Configuration
# Lokalnie: http://localhost:3000 | Produkcja: https://najemokazjonalny24.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$YourHashedPasswordHere

# JWT Secret (generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-secret-key-change-this-in-production

# Przelewy24 (PayPro S.A.) — dane z panelu Przelewy24
# P24_SANDBOX=true → sandbox.przelewy24.pl | false → secure.przelewy24.pl
P24_SANDBOX=true
P24_MERCHANT_ID=your-merchant-id
P24_POS_ID=your-pos-id
P24_CRC=your-crc-key
P24_API_KEY=your-rest-api-key

# Email Configuration (Resend) - https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@najemokazjonalny24.com
EMAIL_TO=kontakt@najemokazjonalny24.com

# Cron secret (chroni /api/cron/reminders — przypomnienia po roku)
CRON_SECRET=

# InPost Geowidget (opcjonalny token wyboru paczkomatu na mapie)
NEXT_PUBLIC_INPOST_GEOWIDGET_TOKEN=

# InPost ShipX (tworzenie przesyłek/etykiet — opcjonalne)
INPOST_SANDBOX=true
INPOST_SHIPX_TOKEN=
INPOST_ORGANIZATION_ID=
INPOST_SENDER_NAME=
INPOST_SENDER_EMAIL=
INPOST_SENDER_PHONE=

# Contact Information
NEXT_PUBLIC_PHONE=+48 123 456 789
NEXT_PUBLIC_EMAIL=kontakt@najemokazjonalny24.com
NEXT_PUBLIC_WHATSAPP=48123456789
